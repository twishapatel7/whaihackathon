# Python FastAPI backend (gap detection + answer submission)
# Run: cd python-backend && uvicorn main:app --reload
VITE_API_BASE_URL=http://localhost:8000

# Property ID to load gaps for (must match a row in your CSV data)
VITE_PROPERTY_ID=

# Next.js backend URL (Vapi outbound calls + LLM webhook)
# Run: cd backend && npm run dev
# For production use your public URL (ngrok or deployed URL)
VITE_BACKEND_URL=http://localhost:3000

# OpenAI key used by the frontend Scout game to generate dynamic questions
VITE_OPENAI_API_KEY=
