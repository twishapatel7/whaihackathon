# Vapi (required for real calls unless VOICE_MOCK_MODE=true)
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# Public HTTPS base where Vapi reaches this app (ngrok, etc.) — required for custom LLM
NEXT_PUBLIC_BASE_URL=https://your-host.example

# OpenAI (server-side; used by /api/vapi/llm and post-call extraction)
OPENAI_API_KEY=

# Optional: skip real OpenAI in /api/vapi/llm only (still uses OpenAI for end-of-call extraction unless you change that)
LLM_MOCK_MODE=false

# Optional: skip placing real phone calls (returns mock call id)
VOICE_MOCK_MODE=false

# Branding
NEXT_PUBLIC_HOTEL_NAME=Grand Plaza Hotel

# Gap detection service (falls back to built-in topics if unreachable)
GAP_DETECTION_SERVICE_URL=http://localhost:8000
PROPERTY_ID=

# Supabase — prefer service role on the server so RLS does not block upserts
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# TTS: omit or "vapi" (default Clara). Set VAPI_TTS_PROVIDER=playht for PlayHT.
# VAPI_TTS_PROVIDER=vapi
# VAPI_VAPI_VOICE_ID=Clara
# VAPI_PLAYHT_VOICE_ID=

# Vite mock UI (frontend/): VITE_BACKEND_URL or EXPO_PUBLIC_BACKEND_URL → this backend origin
